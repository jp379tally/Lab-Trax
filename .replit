modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "vm"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "EAS iOS Build + Submit"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "desktop-full-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-all"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Desktop Build + Publish"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "desktop-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mobile-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "scripts-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "knowledge-test"

[[workflows.workflow]]
name = "EAS iOS Build + Submit"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/eas-ios-build.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "desktop-full-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/labtrax-desktop run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck-all"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck"

[[workflows.workflow]]
name = "Desktop Build + Publish"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/desktop-build-publish.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "desktop-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/labtrax-desktop run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "mobile-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/labtrax run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "scripts-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "knowledge-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/ai-knowledge run test"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 600000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 18803
externalPort = 3001

[[ports]]
localPort = 19134
externalPort = 3000

[[ports]]
localPort = 19135
externalPort = 4200

[nix]
channel = "stable-25_05"

[userenv]

