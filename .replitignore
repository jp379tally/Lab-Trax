# The format of this file is identical to `.dockerignore`.
# It is used to reduce the size of deployed images to make the process of publishing faster.

# Agent/local working files.
.local

# Dependencies.
node_modules

# Build output.
dist
build
static-build
electron-dist
.expo
.cache

# Heavy runtime artifacts.
uploads
attached_assets
logs

# Packaged binaries / archives.
*.zip
*.exe
*.dmg
*.msi
*.pkg
*.ipa
*.tar.gz
