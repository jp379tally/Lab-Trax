# Node modules — EAS installs these on its build servers
node_modules/
.pnpm-store/

# Git history
.git/

# Build outputs
dist/
build/
static-build/
server_dist/
.expo/
*.tsbuildinfo

# Desktop app — not needed for mobile build (Electron binaries are huge)
artifacts/labtrax-desktop/

# API server artifact — not needed for mobile build
artifacts/api-server/

# Mockup sandbox — not needed for mobile build
artifacts/mockup-sandbox/

# Large assets — explicit paths in case EAS archives from workspace root
attached_assets/
artifacts/labtrax/attached_assets/

# Binaries and archives
*.exe
*.zip
*.tar.gz
*.tar.xz
*.dmg
*.pkg

# Logs and temp files
*.log
logs/
tmp/
.local/
