# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Expo native build outputs
ios/build/
android/build/
android/.gradle/

# Static web export
static-build/

# Stale compiled Express server bundle — NOT a production artifact.
# Production serving is `build` (static-build/) + `serve` (server/serve.js).
# Never commit a regenerated bundle here; it can contain legacy-path code that
# is invisible to the mobile legacy-path fence (see scripts/src/lint-mobile-legacy-paths.ts).
server_dist/

# Attached assets archives — large source-zip uploads, never commit
attached_assets/*.zip
attached_assets/*.tar.gz
attached_assets/*.tgz

# Bundled source archives served as downloads
public/downloads/*.tar.gz
public/downloads/*.zip
public/labtrax-source.tar.gz

# Native
ios/
android/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo
.vercel

.env
AuthKey_*.p8
