# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp/
/tmp/
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/
AuthKey_*.p8

# Build / output directories — never commit build artifacts
static-build/
**/static-build/
**/electron-dist/
**/build/
**/out/
**/.turbo/
**/.next/

# Server runtime data — uploaded case media is per-deployment, not source
artifacts/api-server/uploads/

# Migration / backup snapshots — these are throwaway working copies
.migration-backup/

# Archives, installers, and other large binaries
*.tar.gz
*.tar.gz.part
*.tgz
*.zip
*.dmg
*.exe
*.msi
*.pkg
*.AppImage
*.ipa

# Large media uploads — keep on disk if needed, but never commit
*.mp4
*.mov

# Static export output (Expo / Vite)
**/static-build/
exports/

# Logs
*.log
